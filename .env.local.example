# Environment Variables for Taxation is Theft
# Copy this to .env.local and fill in your values

# Database (Neon PostgreSQL)
# Get your connection string from: https://console.neon.tech
DATABASE_URL="postgresql://neondb_owner:...@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Authentication (generate with: openssl rand -base64 32)
JWT_SECRET=""

# OpenAI (for bank statement analysis)
OPENAI_API_KEY="sk-proj-your-key-here"
OPENAI_MODEL="gpt-4o"

# PayFast Payment Gateway
# Get credentials at: https://www.payfast.co.za/registration
# Use sandbox credentials for testing: https://sandbox.payfast.co.za
PAYFAST_MERCHANT_ID="10000100"
PAYFAST_MERCHANT_KEY="46f0cd694581a"
PAYFAST_PASSPHRASE=""

# App URL (used for PayFast return/notify URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@taxationistheft.co.za"
EMAIL_FROM_NAME="Taxation is Theft"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Taxation is Theft"
