generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── Users ──────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String?
  googleId      String?  @unique
  
  // Tax profile
  occupation    String?
  idNumber      String?  // SA ID for tax purposes
  taxNumber     String?  // SARS tax reference number
  dateOfBirth   DateTime?
  entityType    EntityType @default(INDIVIDUAL)
  
  // Extended tax profile (drives AI analysis)
  employmentType      String?  // employed, self_employed, commission, both
  hasMedicalAid       Boolean  @default(false)
  medicalAidMembers   Int?     // number of people on medical aid
  monthlyMedicalAidFee Decimal? @db.Decimal(10, 2)
  hasRetirementAnnuity Boolean @default(false)
  annualRAContribution Decimal? @db.Decimal(12, 2)
  worksFromHome       Boolean  @default(false)
  homeOfficePct       Float?   // % of home used as office
  usesVehicleForWork  Boolean  @default(false)
  annualBusinessKm    Int?
  receivesTravelAllowance Boolean @default(false)
  makesDonations      Boolean  @default(false)
  hasOutOfPocketMedical Boolean @default(false)
  taxProfileComplete  Boolean  @default(false)
  
  // Plan & credits
  planType      PlanType @default(FREE)
  credits       Int      @default(3)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  taxYears      TaxYear[]
  transactions  Transaction[]
  deductions    Deduction[]
  taxReports    TaxReport[]
  payments      Payment[]
  
  @@map("users")
}

// ─── Tax Years ──────────────────────────────────────────
model TaxYear {
  id            String   @id @default(cuid())
  userId        String
  yearLabel     String   // e.g. "2024/2025"
  startDate     DateTime // e.g. 2024-03-01
  endDate       DateTime // e.g. 2025-02-28
  
  // Calculated totals
  totalIncome       Decimal? @db.Decimal(12, 2)
  totalDeductions   Decimal? @db.Decimal(12, 2)
  taxableIncome     Decimal? @db.Decimal(12, 2)
  estimatedTax      Decimal? @db.Decimal(12, 2)
  taxWithDeductions Decimal? @db.Decimal(12, 2)
  taxSavings        Decimal? @db.Decimal(12, 2)
  
  status        TaxYearStatus @default(IN_PROGRESS)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  deductions    Deduction[]
  reports       TaxReport[]
  
  @@unique([userId, yearLabel])
  @@map("tax_years")
}

// ─── Transactions (extracted from bank statements) ──────
model Transaction {
  id            String   @id @default(cuid())
  userId        String
  taxYearId     String?
  
  date          DateTime
  description   String
  amount        Decimal  @db.Decimal(12, 2)
  type          TransactionType // INCOME, EXPENSE, TRANSFER
  
  // AI categorization
  category      String?  // e.g. "OFFICE", "TRAVEL", "SALARY"
  confidence    Float?   // AI confidence score 0-1
  isDeductible  Boolean  @default(false)
  deductiblePct Int      @default(0) // 0-100
  
  // Source tracking
  bankName      String?
  accountNumber String?  // Last 4 digits only
  statementMonth String? // e.g. "2024-03"
  
  // User can override AI
  userCategory  String?
  userOverride  Boolean  @default(false)
  notes         String?
  
  createdAt     DateTime @default(now())
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear       TaxYear? @relation(fields: [taxYearId], references: [id])
  deduction     Deduction?
  
  @@map("transactions")
}

// ─── Deductions ─────────────────────────────────────────
model Deduction {
  id              String   @id @default(cuid())
  userId          String
  taxYearId       String
  transactionId   String?  @unique
  
  category        String   // Expense category
  description     String
  amount          Decimal  @db.Decimal(12, 2)
  deductiblePct   Int      @default(100)
  deductibleAmount Decimal @db.Decimal(12, 2)
  
  // SARS compliance
  vatAmount       Decimal? @db.Decimal(12, 2)
  sarsSection     String?  // e.g. "Section 11(a)"
  requiresProof   Boolean  @default(true)
  proofNotes      String?
  
  status          DeductionStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  
  // Relations
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear         TaxYear     @relation(fields: [taxYearId], references: [id])
  transaction     Transaction? @relation(fields: [transactionId], references: [id])
  
  @@map("deductions")
}

// ─── Tax Reports ────────────────────────────────────────
model TaxReport {
  id            String   @id @default(cuid())
  userId        String
  taxYearId     String
  
  reportType    ReportType
  reportData    Json     // Full calculation breakdown
  
  totalIncome       Decimal @db.Decimal(12, 2)
  totalDeductions   Decimal @db.Decimal(12, 2)
  taxableIncome     Decimal @db.Decimal(12, 2)
  taxPayable        Decimal @db.Decimal(12, 2)
  taxWithout        Decimal @db.Decimal(12, 2) // Tax without deductions
  taxSaved          Decimal @db.Decimal(12, 2)
  
  createdAt     DateTime @default(now())
  
  // Relations
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxYear       TaxYear @relation(fields: [taxYearId], references: [id])
  
  @@map("tax_reports")
}

// ─── Payments (monetization) ────────────────────────────
model Payment {
  id            String   @id @default(cuid())
  userId        String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("ZAR")
  status        PaymentStatus @default(PENDING)
  method        String?
  externalId    String?  // PayPal/Stripe ID
  
  // What they paid for
  creditsPurchased Int?
  planType      PlanType?
  
  createdAt     DateTime @default(now())
  
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("payments")
}

// ─── Enums ──────────────────────────────────────────────
enum EntityType {
  INDIVIDUAL
  COMPANY
  SBC
  TRUST
}

enum PlanType {
  FREE
  PRO
  PREMIUM
}

enum TaxYearStatus {
  IN_PROGRESS
  COMPLETED
  FILED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum DeductionStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum ReportType {
  SUMMARY
  DETAILED
  ITR12_PREP
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
